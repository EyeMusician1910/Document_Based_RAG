# Auto detect text files and normalize line endings to LF
* text=auto

# Python files
*.py text eol=lf
*.pyx text eol=lf
*.pyi text eol=lf

# Notebook files
*.ipynb text eol=lf

# Configuration files
*.toml text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.lock text eol=lf
*.md text eol=lf
.gitignore text eol=lf
.env text eol=lf

# Binary files
*.pkl binary
*.pickle binary
*.pyc binary
*.so binary
